// Tutorial4 - Nextflow 26.04 features
//
// As of 26.04 the strict syntax parser is the DEFAULT. Scripts must comply
// with the Nextflow language specification (no DSL1 from/into, no top-level
// statements mixed with declarations, no System.exit, etc).
//
// Escape hatch (temporary): export NXF_SYNTAX_PARSER=v1 to use the old parser.

params {
  inputCsv = "${projectDir}/samples.csv"
}

manifest {
  homePage    = 'http://mydepotducode'
  description = 'Tutorial Nextflow - 26.04 features'
  version     = 'v1.0.0'
  author      = 'Superman'
  // NOTE (26.04): manifest.defaultBranch is deprecated - Nextflow now detects
  // the default branch of a remote pipeline automatically. Do not set it.
}

profiles {
  standard {
    process.executor = 'local'
  }
  docker {
    docker.enabled = true
  }
}
